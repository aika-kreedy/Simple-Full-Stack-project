
const { Schema, model } = require("mongoose");

const userSchema = new Schema({
    name: {
        type: String,
    },
    email: {
        type: String,
        unique: true,
    },
    age: {
        type: Number,
    },
});

// The first argument in model() is the collection name.
const UserModel = model("users", userSchema);

module.exports = UserModel;
